{
  "name": "serverless-aws-node-chrome",
  "version": "1.0.0",
  "main": "handler.js",
  "author": "Blake Tsuhako",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">= 6.10.0"
  },
  "dependencies": {
    "chrome-remote-interface": "^0.33.0",
    "puppeteer-core": "^24.40.0"
  },
  "devDependencies": {
    "@sparticuz/chromium": "^147.0.0",
    "babel-loader": "^10.1.1",
    "babel-plugin-transform-object-entries": "^1.0.0",
    "babel-plugin-transform-object-rest-spread": "^6.26.0",
    "chrome-launcher": "^0.13.2",
    "eslint": "^10.2.0",
    "serverless-webpack": "^5.15.4",
    "webpack": "^5.106.1"
  },
  "babel": {
    "sourceMaps": true,
    "presets": [
      [
        "env",
        {
          "modules": "commonjs",
          "targets": {
            "node": "6.10"
          },
          "include": [
            "es7.object.values",
            "es7.object.entries"
          ]
        }
      ],
      "stage-3"
    ],
    "plugins": [
      "transform-object-rest-spread",
      "transform-object-entries"
    ]
  },
  "browser": {
    "decompress-response": false,
    "electron": false
  }
}
